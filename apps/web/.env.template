# MiniSave Web — Environment Variables
# Copy to .env.local and fill in values for your target deployment.

# WalletConnect project ID (optional — not needed for MiniPay-only)
NEXT_PUBLIC_WC_PROJECT_ID=

# Target chain: 42220 = Celo Mainnet, 11142220 = Celo Sepolia (testnet)
NEXT_PUBLIC_TARGET_CHAIN_ID=11142220

# Contract addresses — set after deploying PiggyBankFactory + PenaltyReserve
NEXT_PUBLIC_FACTORY_ADDRESS=
NEXT_PUBLIC_PENALTY_RESERVE_ADDRESS=

# Stable token config
# For Celo mainnet cUSD: symbol=cUSD, address=0x765DE816845861e75A25fCA122bb6898B8B1282a, decimals=18
# For USDC on Celo:      symbol=USDC, address=0xcebA9300f2b948710d2653dD7B07f33A8B32118C, decimals=6
# For testnet mock:       symbol=mUSD, address=0x24a4aA28f0bE53f6466BFa681f94aDdb1F26F003, decimals=18
NEXT_PUBLIC_DEFAULT_TOKEN_SYMBOL=mUSD
NEXT_PUBLIC_DEFAULT_TOKEN_ADDRESS=0x24a4aA28f0bE53f6466BFa681f94aDdb1F26F003
NEXT_PUBLIC_DEFAULT_TOKEN_DECIMALS=18
